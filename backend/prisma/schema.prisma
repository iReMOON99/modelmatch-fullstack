generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MODEL
  AGENCY
  ADMIN
}

enum MessageType {
  TEXT
  IMAGE
  STICKER
  GIFT
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          UserRole
  name          String?
  avatarUrl     String?
  balance       Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  modelProfile  ModelProfile?
  agencyProfile AgencyProfile?
  
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  sentGifts     UserGift[] @relation("SentGifts")
  receivedGifts UserGift[] @relation("ReceivedGifts")
}

model ModelProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  displayName  String?
  age          Int?
  country      String?
  city         String?
  height       Int?
  measurements String?
  bio          String?
  experience   String?
  photos       String[] @default([]) // Array of photo URLs
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AgencyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  companyName String
  country     String?
  city        String?
  description String?
  website     String?
  instagram   String?
  photos      String[] @default([]) // Array of photo URLs
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id         String      @id @default(cuid())
  content    String?
  type       MessageType @default(TEXT)
  mediaUrl   String?     // URL for images, stickers
  giftId     String?     // ID of the gift if type is GIFT
  senderId   String
  receiverId String
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
  gift     Gift? @relation(fields: [giftId], references: [id])
}

model Gift {
  id          String     @id @default(cuid())
  name        String
  imageUrl    String
  price       Int
  isActive    Boolean    @default(true)
  messages    Message[]
  userGifts   UserGift[]
}

model UserGift {
  id         String   @id @default(cuid())
  giftId     String
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  gift     Gift @relation(fields: [giftId], references: [id])
  sender   User @relation("SentGifts", fields: [senderId], references: [id])
  receiver User @relation("ReceivedGifts", fields: [receiverId], references: [id])
}

model StickerPack {
  id       String    @id @default(cuid())
  name     String
  stickers Sticker[]
}

model Sticker {
  id          String      @id @default(cuid())
  packId      String
  imageUrl    String
  pack        StickerPack @relation(fields: [packId], references: [id])
}
